<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="medical_support_robot">
  <xacro:include filename="../base_differential_drive.xacro" />
  <xacro:macro name="medical_support_robot">
    <xacro:base_differential_drive prefix="" />
    <!-- Material Definitions -->
    <material name="white">
      <color rgba="1.0 1.0 1.0 1.0" />
    </material>
    <material name="green">
      <color rgba="0.0 1.0 0.0 1.0" />
    </material>
    <!-- Specialized links -->
    <link name="supply_compartment_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0" /><mass value="3.0" /><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" /></inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0" /><geometry><box size="0.3 0.3 0.2" /></geometry><material name="white" /></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0" /><geometry><box size="0.3 0.3 0.2" /></geometry></collision>
    </link>
    <link name="vital_sensors_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0" /><mass value="0.5" /><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" /></inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0" /><geometry><box size="0.1 0.1 0.1" /></geometry><material name="green" /></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0" /><geometry><box size="0.1 0.1 0.1" /></geometry></collision>
    </link>
    <!-- Specialized joints -->
    <joint name="supply_compartment_joint" type="fixed">
      <parent link="base_link" />
      <child link="supply_compartment_link" />
      <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>
    <joint name="vital_sensors_joint" type="fixed">
      <parent link="base_link" />
      <child link="vital_sensors_link" />
      <origin xyz="0.2 0 0.2" rpy="0 0 0" />
    </joint>
    <!-- Gazebo plugins -->
    <gazebo>
      <plugin filename="ign-gazebo-camera-system" name="ignition::gazebo::systems::Camera">
        <topic>/medical_support_robot/vital_camera</topic>
        <camera><horizontal_fov>1.047</horizontal_fov><image><width>320</width><height>240</height></image></camera>
        <link>vital_sensors_link</link>
      </plugin>
    </gazebo>
  </xacro:macro>
  <xacro:medical_support_robot />
</robot>