<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="firefighter_robot">

  <!-- Robot Properties -->
  <xacro:property name="base_length" value="0.5"/>
  <xacro:property name="base_width" value="0.3"/>
  <xacro:property name="base_height" value="0.1"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_ygap" value="0.2"/>
  <xacro:property name="wheel_xoff" value="0.15"/>
  <xacro:property name="wheel_zoff" value="0.05"/>
  <xacro:property name="caster_radius" value="0.025"/>
  <xacro:property name="caster_xoff" value="-0.15"/>

  <!-- Base Link (Heat-Resistant Chassis) -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/> <!-- Heat-resistant material -->
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <!-- Left Wheel Joint -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="${wheel_xoff} ${wheel_ygap} ${wheel_zoff}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <!-- Right Wheel Joint -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="${wheel_xoff} -${wheel_ygap} ${wheel_zoff}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Caster Wheel -->
  <link name="caster">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
  </link>

  <!-- Caster Joint -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="${caster_xoff} 0 ${caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- Sensor Mount (For Temperature and Gas Sensors) -->
  <link name="sensor_mount">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.1"/>
      </geometry>
      <material name="grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Sensor Mount Joint -->
  <joint name="sensor_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mount"/>
    <origin xyz="0.2 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- Specialized Links for Firefighter Robot (Document 5, Page 1) -->
  <!-- Thermal Camera -->
  <link name="thermal_camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Water Tank (for Water/Foam Dispensing) -->
  <link name="water_tank_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.3"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <!-- Pump (for Water/Foam Dispensing) -->
  <link name="pump_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.2"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- High-Intensity Light -->
  <link name="light_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Joints for Specialized Components -->
  <joint name="thermal_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="thermal_camera_link"/>
    <origin xyz="0.2 0.1 0.2" rpy="0 0 0"/>
  </joint>

  <joint name="water_tank_joint" type="fixed">
    <parent link="base_link"/>
    <child link="water_tank_link"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
  </joint>

  <joint name="pump_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pump_link"/>
    <origin xyz="-0.2 0 0.1" rpy="0 0 0"/>
  </joint>

  <joint name="light_joint" type="fixed">
    <parent link="base_link"/>
    <child link="light_link"/>
    <origin xyz="0.2 -0.1 0.2" rpy="0 0 0"/>
  </joint>

  <!-- Ignition Gazebo Plugins -->
  <gazebo>
    <!-- Differential Drive System -->
    <plugin filename="ign-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${2 * wheel_ygap}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- IMU Sensor (For Temperature/Gas Sensors) -->
    <plugin filename="ign-gazebo-imu-system" name="ignition::gazebo::systems::Imu">
      <topic>/firefighter_robot/imu</topic>
      <update_rate>100</update_rate>
    </plugin>

    <!-- Material Colors for Ignition Gazebo -->
    <material reference="base_link">
      <ambient>0.75 0.75 0.75 1.0</ambient>
      <diffuse>0.75 0.75 0.75 1.0</diffuse>
    </material>
    <material reference="left_wheel">
      <ambient>0.1 0.1 0.1 1.0</ambient>
      <diffuse>0.1 0.1 0.1 1.0</diffuse>
    </material>
    <material reference="right_wheel">
      <ambient>0.1 0.1 0.1 1.0</ambient>
      <diffuse>0.1 0.1 0.1 1.0</diffuse>
    </material>
    <material reference="caster">
      <ambient>0.1 0.1 0.1 1.0</ambient>
      <diffuse>0.1 0.1 0.1 1.0</diffuse>
    </material>
    <material reference="sensor_mount">
      <ambient>0.3 0.3 0.3 1.0</ambient>
      <diffuse>0.3 0.3 0.3 1.0</diffuse>
    </material>
    <material reference="thermal_camera_link">
      <ambient>0.0 0.0 0.0 1.0</ambient>
      <diffuse>0.0 0.0 0.0 1.0</diffuse>
    </material>
    <material reference="water_tank_link">
      <ambient>0.0 0.0 1.0 1.0</ambient>
      <diffuse>0.0 0.0 1.0 1.0</diffuse>
    </material>
    <material reference="pump_link">
      <ambient>0.75 0.75 0.75 1.0</ambient>
      <diffuse>0.75 0.75 0.75 1.0</diffuse>
    </material>
    <material reference="light_link">
      <ambient>1.0 1.0 1.0 1.0</ambient>
      <diffuse>1.0 1.0 1.0 1.0</diffuse>
      <emissive>1.0 1.0 1.0 1.0</emissive>
    </material>
  </gazebo>

</robot>
